<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Hug\EuLabel\Service\LabelProvider">
            <argument type="service" id="language.repository"/>
            <argument type="service" id="logger" on-invalid="null"/>
            <tag name="monolog.logger" channel="hug_eu_label"/>
        </service>

        <service id="Hug\EuLabel\Service\OrderConfirmationMailChecker">
            <argument type="service" id="mail_template_type.repository"/>
        </service>

        <service id="Hug\EuLabel\Subscriber\MailAttachmentSubscriber">
            <argument type="service" id="Hug\EuLabel\Service\LabelProvider"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="Hug\EuLabel\Service\OrderConfirmationMailChecker"/>
            <argument type="service" id="logger" on-invalid="null"/>
            <tag name="kernel.event_subscriber"/>
            <tag name="monolog.logger" channel="hug_eu_label"/>
        </service>

        <service id="Hug\EuLabel\Service\GaranConditionsFileLoader">
            <argument type="service" id="media.repository"/>
            <argument type="service" id="shopware.filesystem.public"/>
            <argument type="service" id="logger" on-invalid="null"/>
            <tag name="monolog.logger" channel="hug_eu_label"/>
        </service>

        <service id="Hug\EuLabel\Service\GaranSummaryPdfGenerator">
            <argument type="service" id="twig"/>
            <argument type="service" id="logger" on-invalid="null"/>
            <tag name="monolog.logger" channel="hug_eu_label"/>
        </service>

        <service id="Hug\EuLabel\Subscriber\GaranMailSubscriber">
            <argument type="service" id="Hug\EuLabel\Service\GaranDataResolver"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="Hug\EuLabel\Service\OrderConfirmationMailChecker"/>
            <argument type="service" id="order.repository"/>
            <argument type="service" id="Hug\EuLabel\Service\GaranConditionsFileLoader"/>
            <argument type="service" id="Hug\EuLabel\Service\GaranSummaryPdfGenerator"/>
            <argument type="service" id="logger" on-invalid="null"/>
            <tag name="kernel.event_subscriber"/>
            <tag name="monolog.logger" channel="hug_eu_label"/>
        </service>

<service id="Hug\EuLabel\Service\RepositoryGaranMediaUrlResolver">
            <argument type="service" id="media.repository"/>
        </service>

        <service id="Hug\EuLabel\Service\GaranMediaUrlResolver" alias="Hug\EuLabel\Service\RepositoryGaranMediaUrlResolver"/>

        <service id="Hug\EuLabel\Service\GaranDataResolver">
            <argument type="service" id="Hug\EuLabel\Service\GaranMediaUrlResolver"/>
            <argument type="service" id="logger" on-invalid="null"/>
            <argument type="service" id="product_manufacturer.repository"/>
            <tag name="monolog.logger" channel="hug_eu_label"/>
        </service>

        <service id="Hug\EuLabel\Service\GpsrProvider">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Hug\EuLabel\Service\GaranLabelRenderer">
            <argument type="service" id="logger" on-invalid="null"/>
            <tag name="monolog.logger" channel="hug_eu_label"/>
        </service>

        <service id="Hug\EuLabel\Service\GaranLabelService">
            <argument type="service" id="Hug\EuLabel\Service\GaranDataResolver"/>
            <argument type="service" id="Hug\EuLabel\Service\GaranLabelRenderer"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="cache.object"/>
        </service>

        <service id="Hug\EuLabel\Storefront\Twig\GaranExtension">
            <argument type="service" id="Hug\EuLabel\Service\GaranLabelService"/>
            <argument type="service" id="product.repository"/>
            <tag name="twig.extension"/>
        </service>

        <service id="Hug\EuLabel\Storefront\Controller\GaranLabelController" public="true">
            <argument type="service" id="Hug\EuLabel\Service\GaranLabelService"/>
            <argument type="service" id="product.repository"/>
            <tag name="controller.service_arguments"/>
        </service>

        <service id="Hug\EuLabel\Storefront\Twig\EuLabelExtension">
            <argument type="service" id="Hug\EuLabel\Service\LabelProvider"/>
            <tag name="twig.extension"/>
        </service>

        <service id="Hug\EuLabel\Storefront\Twig\GpsrExtension">
            <argument type="service" id="Hug\EuLabel\Service\GpsrProvider"/>
            <tag name="twig.extension"/>
        </service>
    </services>
</container>
